    "build":      "vite build",
    "start":      "node server/index.js"
  },
  "dependencies": {
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.19.2",
    "react":       "^18.3.1",
    "react-dom":   "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently":         "^9.0.1",
    "nodemon":              "^3.1.4",
    "vite":                 "^5.4.0"
  }
}
